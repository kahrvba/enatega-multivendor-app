{
  "cli": { "version": ">= 10.0.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" },
      "autoIncrement": true,
      "env": {
        "NPM_CONFIG_PACKAGE_MANAGER": "pnpm",
        "RCT_NEW_ARCH_ENABLED": "1"
      }
    },
    "production": {
      "channel": "production",
      "distribution": "internal",
      "environment": "production",
      "ios": { "image": "latest" },
      "android": { "buildType": "apk" },
      "autoIncrement": true,
      "env": {
        "NPM_CONFIG_PACKAGE_MANAGER": "pnpm",
        "RCT_NEW_ARCH_ENABLED": "1"
      }
    }
  },
  "submit": { "production": {} }
}
